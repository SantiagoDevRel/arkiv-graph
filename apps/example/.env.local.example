# Copy to .env.local and fill in. The wallet MUST be a throwaway Braga testnet
# burner (valueless test GLM only) — never a mainnet key.

# Signs the seed + the live "post on-chain" button. Get test GLM:
# https://braga.hoodi.arkiv.network/faucet/
PRIVATE_KEY=0xyour_braga_testnet_burner_private_key

# Public address of that wallet. Reads filter by it (createdBy) so you only graph
# your own demo data on the shared testnet. If omitted, it's derived from PRIVATE_KEY.
TRUSTED_ADDRESS=0xyour_braga_testnet_burner_address

# Project namespace stamped on every entity (and used in read queries).
ARKIV_PROJECT=arkiv-graph-demo-v1

# Set to 1 to enable the live write endpoint (/api/post). Leave unset to make the
# showcase read-only.
ENABLE_WRITES=1

# ── Network (plug-and-play) ──────────────────────────────────────────────────
# Defaults to Braga. When Braga is sunset, point at the next Arkiv testnet by
# setting these — NO code change. (If the SDK ships the next network as a chain
# export, you can instead swap the `braga` import in src/lib/arkiv.ts.)
# ARKIV_CHAIN_ID=60138453102
# ARKIV_RPC_URL=https://braga.hoodi.arkiv.network/rpc
# ARKIV_WS_URL=wss://braga.hoodi.arkiv.network/rpc/ws
# ARKIV_EXPLORER_URL=https://explorer.braga.hoodi.arkiv.network
# ARKIV_FAUCET_URL=https://braga.hoodi.arkiv.network/faucet/
# ARKIV_GAS_TOKEN=GLM
# ARKIV_NETWORK_NAME=Braga
