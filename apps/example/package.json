{
  "name": "@arkiv-graph/example",
  "version": "0.1.0",
  "private": true,
  "description": "Live showcase for arkiv-graph — a fake social app stored entirely on an Arkiv testnet, visualized as a graph and tables.",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter arkiv-graph build",
    "dev": "next dev -p 3012",
    "build": "next build",
    "start": "next start -p 3012",
    "seed": "node scripts/seed.mjs",
    "seed:reseed": "node scripts/seed.mjs --reseed"
  },
  "dependencies": {
    "@arkiv-network/sdk": "^0.6.8",
    "arkiv-graph": "workspace:*",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.7",
    "typescript": "^5.6.3"
  }
}
